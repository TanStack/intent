{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": ["@faker-js/faker"],
  "ignoreBinaries": ["tsx"],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts"]
    },
    "packages/intent": {
      "entry": [
        "src/index.ts",
        "src/cli.ts",
        "src/setup.ts",
        "src/intent-library.ts",
        "src/library-scanner.ts"
      ],
      "ignore": ["meta/**"]
    }
  }
}
